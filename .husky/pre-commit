#!/bin/sh
# Pre-commit hook: Run linting and basic tests before commit
# Prevents commits with linting errors or failing tests

set -e

echo "🔍 Running pre-commit checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Filter for frontend files
FRONTEND_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' | grep -v 'node_modules' || true)

# Filter for backend files
BACKEND_FILES=$(echo "$STAGED_FILES" | grep -E '\.py$' | grep -v '__pycache__' || true)

# Frontend checks
if [ -n "$FRONTEND_FILES" ]; then
    echo "📦 Linting frontend code..."
    cd frontend

    # Run ESLint if available
    if npm ls eslint > /dev/null 2>&1; then
        npx eslint $FRONTEND_FILES --fix --max-warnings=0 || {
            echo "❌ ESLint check failed. Fix errors and try again."
            exit 1
        }
    else
        echo "⚠️  ESLint not installed, skipping"
    fi

    # Run Prettier if available
    if npm ls prettier > /dev/null 2>&1; then
        npx prettier --check $FRONTEND_FILES || {
            echo "⚠️  Running prettier --write to fix formatting..."
            npx prettier --write $FRONTEND_FILES
        }
    fi

    cd ..
fi

# Backend checks
if [ -n "$BACKEND_FILES" ]; then
    echo "🐍 Linting backend code..."
    cd backend/python

    # Check Python syntax
    python -m py_compile $BACKEND_FILES || {
        echo "❌ Python syntax error. Fix and try again."
        exit 1
    }

    # Run flake8 if available
    if command -v flake8 > /dev/null 2>&1; then
        flake8 $BACKEND_FILES --max-line-length=120 || {
            echo "⚠️  Flake8 warnings found. Consider fixing them."
        }
    fi

    # Run Black formatter if available
    if command -v black > /dev/null 2>&1; then
        black $BACKEND_FILES --check || {
            echo "⚠️  Running black to format code..."
            black $BACKEND_FILES
        }
    fi

    cd ../..
fi

# Re-stage formatted files
if [ -n "$FRONTEND_FILES" ] || [ -n "$BACKEND_FILES" ]; then
    git add $STAGED_FILES
fi

echo "✅ Pre-commit checks passed!"
exit 0
