# Production Environment Configuration
# Used for production environment - highest security and performance

# Database (connect to production database - managed service)
DATABASE_URL=postgresql://touchcli_user:${PROD_DB_PASSWORD}@postgres.touchcli.io:5432/touchcli_prod
POSTGRES_DB=touchcli_prod
POSTGRES_USER=touchcli_user

# Redis (managed service for high availability)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis.touchcli.io:6379

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=https://api.touchcli.io

# Frontend
FRONTEND_URL=https://touchcli.io
VITE_API_URL=https://api.touchcli.io
VITE_WS_URL=wss://api.touchcli.io/ws

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_URL=https://api.touchcli.io

# Environment (NEVER DEBUG IN PRODUCTION)
ENVIRONMENT=production
LOG_LEVEL=WARN

# JWT (use secure key from secrets - MUST be strong)
JWT_SECRET=${JWT_SECRET_PROD}
JWT_EXPIRATION=3600

# CORS (restrict to production domain only)
CORS_ALLOWED_ORIGINS=https://touchcli.io,https://api.touchcli.io

# AI/LLM (use production credentials)
OPENAI_API_KEY=${OPENAI_API_KEY_PROD}
LANGGRAPH_API_KEY=${LANGGRAPH_API_KEY_PROD}

# Celery (Background tasks)
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis.touchcli.io:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis.touchcli.io:6379/1

# Application
APP_NAME=TouchCLI
APP_VERSION=1.0.0

# Feature flags (stable features only in production)
FEATURE_ADVANCED_SEARCH=true
FEATURE_REPORTS=true
FEATURE_MULTI_TENANT=false

# Security
SECURE_COOKIES=true
HTTPS_ONLY=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# Monitoring (full monitoring in production)
ENABLE_METRICS=true
ENABLE_TRACING=true
SENTRY_DSN=${SENTRY_DSN_PROD}
DATADOG_API_KEY=${DATADOG_API_KEY}

# Database backups (daily, long retention)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Performance
MAX_CONNECTIONS_POOL=20
QUERY_TIMEOUT=30000
CACHE_TTL=3600

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Email (for notifications)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@touchcli.io
