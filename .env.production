# TouchCLI Production Environment Configuration
# Last Updated: 2026-03-02
# CRITICAL: Never commit real secrets to this file
# Use environment variables or secrets management (Vault, AWS Secrets Manager, etc.)

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# IMPORTANT: Use read replicas and connection pooling in production
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=touchcli_production_db
DATABASE_URL=${DATABASE_URL}

# Connection pooling for production
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=3600

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Use managed Redis service (e.g., AWS ElastiCache) in production
REDIS_URL=${REDIS_URL}
REDIS_PASSWORD=${REDIS_PASSWORD}
CELERY_BROKER_URL=${CELERY_BROKER_URL}
CELERY_RESULT_BACKEND=${CELERY_RESULT_BACKEND}

# Redis connection pooling
REDIS_POOL_SIZE=50
REDIS_SOCKET_KEEPALIVE=true
REDIS_SOCKET_KEEPALIVE_DELAY=30

# ============================================================================
# AUTHENTICATION
# ============================================================================
# CRITICAL: Use strong, randomly generated JWT secret
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=2592000

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=WARNING
LOG_FORMAT=json

# ============================================================================
# GATEWAY CONFIGURATION
# ============================================================================
GATEWAY_PORT=8080
GIN_MODE=release

# ============================================================================
# API CONFIGURATION
# ============================================================================
AGENT_SERVICE_URL=http://agent-service.default.svc.cluster.local:8000
API_URL=https://api.example.com
VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://api.example.com/ws

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Enable security features
ENABLE_HTTPS=true
ENABLE_HSTS=true
ENABLE_CSP=true

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline' https://cdn.example.com
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_FONT_SRC='self'
CSP_IMG_SRC='self' https:
CSP_CONNECT_SRC='self' https:

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true
JAEGER_AGENT_HOST=jaeger-agent.monitoring.svc.cluster.local
JAEGER_AGENT_PORT=6831

# ============================================================================
# LLM/AI CONFIGURATION
# ============================================================================
# CRITICAL: Use secrets management for API keys
OPENAI_API_KEY=${OPENAI_API_KEY}
LANGGRAPH_API_KEY=${LANGGRAPH_API_KEY}

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=/var/data/uploads
UPLOAD_STORAGE_TYPE=s3
S3_BUCKET=touchcli-uploads-prod
S3_REGION=us-east-1

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=10000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_BURST=100

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * * # Daily at 3 AM UTC
BACKUP_RETENTION_DAYS=90
BACKUP_STORAGE_TYPE=s3
BACKUP_S3_BUCKET=touchcli-backups-prod

# ============================================================================
# DISASTER RECOVERY
# ============================================================================
# Replication configuration
REPLICA_ENABLED=true
REPLICA_HOST=${REPLICA_HOST}
REPLICA_PORT=5432

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
# Query caching
CACHE_ENABLED=true
CACHE_TTL=300

# Connection optimization
KEEPALIVE_TIMEOUT=65
READ_TIMEOUT=30
WRITE_TIMEOUT=30

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features without redeployment
FEATURE_ADVANCED_SEARCH=true
FEATURE_REPORTS=true
FEATURE_BULK_OPERATIONS=true
FEATURE_API_WEBHOOKS=true

# ============================================================================
# ALERT CONFIGURATION
# ============================================================================
ALERT_ENABLED=true
ALERT_SLACK_WEBHOOK=${ALERT_SLACK_WEBHOOK}
ALERT_EMAIL=ops@example.com
ALERT_PagerDuty_KEY=${ALERT_PAGERDUTY_KEY}
