# Development Environment Configuration
# Used by docker-compose and local development

# Database
DATABASE_URL=postgresql://touchcli_user:dev_password@localhost:5432/touchcli_dev
POSTGRES_DB=touchcli_dev
POSTGRES_USER=touchcli_user
POSTGRES_PASSWORD=dev_password

# Redis
REDIS_URL=redis://localhost:6379

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8080/ws

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_URL=http://localhost:8080

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# JWT
JWT_SECRET=dev-secret-key-do-not-use-in-production

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# AI/LLM (Optional - use dummy values for testing)
OPENAI_API_KEY=sk-test-dummy-key-do-not-use
LANGGRAPH_API_KEY=test-dummy-key-do-not-use

# Celery (Background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application
APP_NAME=TouchCLI
APP_VERSION=1.0.0

# Feature flags
FEATURE_ADVANCED_SEARCH=true
FEATURE_REPORTS=false
FEATURE_MULTI_TENANT=false
