# TouchCLI Environment Configuration (Phase 2)
# Copy to .env for local development

# Database
DATABASE_URL=postgresql://touchcli_user:touchcli_password@localhost:5432/touchcli_db
POSTGRES_USER=touchcli_user
POSTGRES_PASSWORD=touchcli_password
POSTGRES_DB=touchcli_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LangGraph Agent Framework
LANGGRAPH_API_KEY=sk-xxxx-your-key-here
OPENAI_API_KEY=sk-xxxx-your-key-here

# Celery Task Queue
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Server Configuration
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text
LOG_FILE=/var/log/touchcli/agent_service.log

# Development
DEBUG=false
ENVIRONMENT=development  # development, staging, production
