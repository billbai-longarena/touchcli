# Staging Environment Configuration
# Used for staging/testing environment before production

# Database (connect to staging database)
DATABASE_URL=postgresql://touchcli_user:${STAGING_DB_PASSWORD}@postgres-staging.internal:5432/touchcli_staging
POSTGRES_DB=touchcli_staging
POSTGRES_USER=touchcli_user

# Redis
REDIS_URL=redis://redis-staging.internal:6379

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=https://staging-api.touchcli.io

# Frontend
FRONTEND_URL=https://staging.touchcli.io
VITE_API_URL=https://staging-api.touchcli.io
VITE_WS_URL=wss://staging-api.touchcli.io/ws

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_URL=https://staging-api.touchcli.io

# Environment
ENVIRONMENT=staging
LOG_LEVEL=INFO

# JWT (use secure key from secrets)
JWT_SECRET=${JWT_SECRET_STAGING}

# CORS
CORS_ALLOWED_ORIGINS=https://staging.touchcli.io,https://staging-api.touchcli.io

# AI/LLM (use staging credentials)
OPENAI_API_KEY=${OPENAI_API_KEY_STAGING}
LANGGRAPH_API_KEY=${LANGGRAPH_API_KEY_STAGING}

# Celery (Background tasks)
CELERY_BROKER_URL=redis://redis-staging.internal:6379/0
CELERY_RESULT_BACKEND=redis://redis-staging.internal:6379/1

# Application
APP_NAME=TouchCLI Staging
APP_VERSION=1.0.0

# Feature flags (test new features here)
FEATURE_ADVANCED_SEARCH=true
FEATURE_REPORTS=true
FEATURE_MULTI_TENANT=false

# Monitoring (enable full monitoring)
ENABLE_METRICS=true
ENABLE_TRACING=true
SENTRY_DSN=${SENTRY_DSN_STAGING}

# Database backups (daily)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
