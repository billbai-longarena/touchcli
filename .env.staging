# TouchCLI Staging Environment Configuration
# Last Updated: 2026-03-02
# Used for staging deployment and testing before production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=touchcli_staging_user
POSTGRES_PASSWORD=changeme-staging-password
POSTGRES_DB=touchcli_staging_db
DATABASE_URL=postgresql://touchcli_staging_user:changeme-staging-password@postgres.staging.internal:5432/touchcli_staging_db

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis.staging.internal:6379/0
CELERY_BROKER_URL=redis://redis.staging.internal:6379/1
CELERY_RESULT_BACKEND=redis://redis.staging.internal:6379/2

# ============================================================================
# AUTHENTICATION
# ============================================================================
# IMPORTANT: Generate a strong JWT secret for staging
JWT_SECRET=change-this-to-a-strong-staging-secret-min-32-chars

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
ENVIRONMENT=staging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# GATEWAY CONFIGURATION
# ============================================================================
GATEWAY_PORT=8080
GIN_MODE=release

# ============================================================================
# API CONFIGURATION
# ============================================================================
AGENT_SERVICE_URL=http://agent_service.staging.internal:8000
API_URL=https://api.staging.example.com
VITE_API_URL=https://api.staging.example.com
VITE_WS_URL=wss://api.staging.example.com/ws

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Enable structured logging
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# LLM/AI CONFIGURATION (Optional)
# ============================================================================
# These should be set via GitHub Secrets in CI/CD, not in this file
# OPENAI_API_KEY=<set in CI/CD secrets>
# LANGGRAPH_API_KEY=<set in CI/CD secrets>

# ============================================================================
# CORS CONFIGURATION (For API Gateway)
# ============================================================================
ALLOWED_ORIGINS=https://app.staging.example.com,https://admin.staging.example.com
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_TIMEOUT=3600
REFRESH_TOKEN_EXPIRY=2592000

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=/data/uploads

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
